# osto-auth-cli Environment Variables

# Absolute or relative path to the SQLite database file
DB_PATH=/data/osto.db

# Go duration string for how long a session should last (e.g., 15m, 1h, 24h)
SESSION_TIME=24h

# 32-byte encryption key for AES-GCM (base64 encoded). Must be exactly 32 bytes when decoded.
# Example generated via: openssl rand -base64 32
APP_ENCRYPTION_KEY=WkX4y9/wL+J+QJzVv7T1P2zN8wR1nB/rY3+L8cQ+x9o=

# Logging level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Background interval for cleaning up expired sessions (default: 1m)
CLEANUP_INTERVAL=1m

# Number of failed login attempts before an account is locked (default: 5)
LOCKOUT_THRESHOLD=5

# Lockout duration after reaching the threshold (default: 15m)
LOCKOUT_DURATION=15m
